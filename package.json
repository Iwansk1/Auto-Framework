{
    "name": "automotive-framework",
    "private": true,
    "workspaces": [
        "packages/*",
        "apps/*"
    ],
    "scripts": {
        "dev": "npm run dev --workspace=apps/demo",
        "dev:core": "npx tsc --watch --project packages/core/tsconfig.json",
        "dev:react": "npx tsc --watch --project packages/react/tsconfig.json",
        "build:core": "npm run build --workspace=packages/core",
        "build:react": "npm run build --workspace=packages/react",
        "build": "npm run build:core && npm run build:react"
    },
    "dependencies": {
        "pg": "^8.20.0"
    }
}
